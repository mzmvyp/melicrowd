# =============================================================================
# MeliCrowd — variáveis de ambiente
# Copie este arquivo para .env e ajuste conforme necessário.
# NUNCA commite o arquivo .env (já está no .gitignore).
# Todas as vars usam prefixo MELICROWD_ (ver src/melicrowd/config.py).
# =============================================================================

# -----------------------------------------------------------------------------
# Qwen / Ollama (LLM local — modelo qwen3:8b)
# -----------------------------------------------------------------------------
# Endpoint do Ollama no host. host.docker.internal funciona no Docker Desktop
# (Windows/Mac). Em Linux puro, ajuste para o IP do host (ex: 172.17.0.1).
MELICROWD_QWEN_BASE_URL=http://host.docker.internal:11434
MELICROWD_QWEN_MODEL=qwen3:8b
MELICROWD_QWEN_TIMEOUT_SECONDS=60
# Limite de chamadas concorrentes ao Qwen (semaphore async no MeliCrowd).
# Default no código: 12. Aumente se o Ollama/GPU aguentar (monitore latência e VRAM);
# diminua se aparecer timeout ou fila enorme no /pool (qwen_waiting).
MELICROWD_QWEN_MAX_CONCURRENT=8
#
# AMD + Windows: Vulkan vs ROCm afeta o Ollama no host, não esta variável.
# Use build/documentação do Ollama para seu GPU; benchmark tokens/s e ajuste este número.

# ---- Otimizações de Qwen — corta latência ~30-40% ----
# Tokens máximos no output (JSON da decisão é pequeno; default 256 cobre todos os schemas).
MELICROWD_QWEN_MAX_OUTPUT_TOKENS=256
# Temperatura baixa = JSON mais previsível, menos parse retries.
MELICROWD_QWEN_TEMPERATURE=0.3
# Skip Qwen no evaluate_item (3-8 chamadas/sessão = maior fonte de calls).
# Fallback procedural (modulado por persona) entrega ~95% do realismo.
# Set true se quiser o realismo extra do LLM avaliando produto-a-produto.
MELICROWD_QWEN_EVALUATE_ITEM_ENABLED=false
# Qwen 3 / Gemma 4 thinking mode: false = JSON direto (3x mais rápido + funciona).
# true = LLM "raciocina" antes de responder mas consome tokens e devolve {}
# vazio quando num_predict é baixo.
MELICROWD_QWEN_THINKING_ENABLED=false

# -----------------------------------------------------------------------------
# Integração com Melisim (api-gateway)
# Hostname interno (rede docker melisim_melisim). Externamente é localhost:18000.
# -----------------------------------------------------------------------------
MELICROWD_MELISIM_GATEWAY_URL=http://melisim-api-gateway:8000
MELICROWD_MELISIM_DEFAULT_TIMEOUT=5.0
# Token bucket interno: respeitar rate limit do gateway (default 100 req/min).
MELICROWD_MELISIM_RATE_LIMIT_PER_MINUTE=100

# -----------------------------------------------------------------------------
# Integração com MeliSimLake (Kafka + Schema Registry)
# Hostnames internos (rede docker melisimlake-net).
# -----------------------------------------------------------------------------
MELICROWD_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
MELICROWD_SCHEMA_REGISTRY_URL=http://schema-registry:8081
# Kafka opcional: se o broker não estiver acessível, publisher entra em modo
# degraded (no-op silencioso) e o pool segue rodando. Set false pra desligar
# de vez (pula o connect-attempt na inicialização do /start).
MELICROWD_KAFKA_ENABLED=true
MELICROWD_KAFKA_CONNECT_TIMEOUT_SECONDS=5.0
# Tópicos publicados pelo MeliCrowd (telemetria enriquecida de agente).
MELICROWD_KAFKA_TOPIC_SESSION_STARTED=events.simulator.session_started
MELICROWD_KAFKA_TOPIC_DECISION_MADE=events.simulator.decision_made
MELICROWD_KAFKA_TOPIC_SESSION_ENDED=events.simulator.session_ended

# -----------------------------------------------------------------------------
# Persistência
# -----------------------------------------------------------------------------
# Postgres do MeliCrowd: porta host 5437 (5436 é usada pelo postgres-feast do melisimlake).
MELICROWD_POSTGRES_DSN=postgresql+asyncpg://melicrowd:melicrowd123@postgres-melicrowd:5432/melicrowd
# Mesmo DSN no formato sync, usado pelo Alembic.
MELICROWD_POSTGRES_DSN_SYNC=postgresql+psycopg2://melicrowd:melicrowd123@postgres-melicrowd:5432/melicrowd

# Redis do MeliCrowd: porta host 6381 (6380 é usada pelo melisim-redis).
MELICROWD_REDIS_URL=redis://redis-melicrowd:6379/0
# TTL do checkpointer LangGraph (segundos). 1h por sessão é suficiente.
MELICROWD_REDIS_CHECKPOINT_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Orchestrator
# -----------------------------------------------------------------------------
# Live Floor: o WebSocket /ws/agents roda na **API** e lê o tracker **dela**.
# Se você usa ``POST /start`` na API, ponha ``false`` aqui para NÃO subir um
# segundo pool no container orchestrator (senão Ollama/DB dobram carga e o
# painel não reflete o que os logs do orchestrator mostram).
MELICROWD_ORCHESTRATOR_AUTOSTART=true
MELICROWD_DEFAULT_AGENT_COUNT=50
# Tempo de espera entre sessões consecutivas do mesmo agente (think time entre logins).
MELICROWD_SESSION_RECYCLE_MIN_SECONDS=30
MELICROWD_SESSION_RECYCLE_MAX_SECONDS=300
# A cada N sessões, recriar usuário BUYER no Melisim (rotação de identidade).
MELICROWD_AUTH_RECYCLE_EVERY_N_SESSIONS=5

# -----------------------------------------------------------------------------
# Error injection (realismo — usuários reais erram)
# -----------------------------------------------------------------------------
MELICROWD_TIMEOUT_INJECTION_RATE=0.05
MELICROWD_FORM_ERROR_INJECTION_RATE=0.02

# -----------------------------------------------------------------------------
# Observabilidade
# -----------------------------------------------------------------------------
MELICROWD_LOG_LEVEL=INFO
MELICROWD_LOG_JSON=false
MELICROWD_PROMETHEUS_METRICS_PORT=9091
# OpenTelemetry (opcional — aponta para o Jaeger do Melisim se quiser traces).
MELICROWD_OTEL_EXPORTER_ENABLED=false
MELICROWD_OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
MELICROWD_OTEL_SERVICE_NAME=melicrowd
# Live Floor: pausa após cada nó rápido (não-Qwen) para a bolinha ficar visível no quadrante.
# 0 = off (produção). Ex.: 1 = ~1s por nó procedural (home, search, pay...) — sessões ficam mais lentas.
MELICROWD_LIVE_FLOOR_FAST_NODE_DELAY_SECONDS=0

# -----------------------------------------------------------------------------
# Control plane (FastAPI)
# -----------------------------------------------------------------------------
MELICROWD_API_HOST=0.0.0.0
MELICROWD_API_PORT=8101
# Rate limit da própria API de controle.
MELICROWD_API_RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# Tech Lead Agent — DeepSeek V4 Pro (API cloud, OpenAI-compatible)
# Obtenha uma chave em https://platform.deepseek.com e cole abaixo.
# A chave NUNCA deve ser commitada — copie este arquivo para .env (gitignored).
# -----------------------------------------------------------------------------
MELICROWD_DEEPSEEK_API_KEY=
MELICROWD_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MELICROWD_DEEPSEEK_MODEL=deepseek-v4-pro
# Intervalo (segundos) entre reavaliações automáticas de tasks em review.
MELICROWD_TECH_LEAD_AUTO_EVALUATE_INTERVAL_SECONDS=300

# Marca o runtime atual; usado pelo evaluator do Tech Lead para escolher entre
# URLs internas (api:8101) ou externas (localhost:8101). Em containers do
# docker-compose, deixe como "container".
MELICROWD_RUNTIME=container
